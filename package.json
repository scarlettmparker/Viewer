{
  "name": "viewer",
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "nodemon",
    "build": "npm run build:client && npm run build:server",
    "build:client": "vite build --ssrManifest --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "graphql:generate": "graphql-codegen --config codegen.ts",
    "lint": "npx eslint",
    "preview": "cross-env NODE_ENV=production tsx --loader ./css-loader.mjs server.js"
  },
  "devDependencies": {
    "@eslint/js": "^9.37.0",
    "@graphql-codegen/cli": "6.0.1",
    "@graphql-codegen/client-preset": "5.1.1",
    "@graphql-codegen/typescript": "^5.0.2",
    "@graphql-codegen/typescript-operations": "^5.0.2",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.0",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.8.0",
    "@types/react-dom": "^19.1.2",
    "baseline-browser-mapping": "^2.9.11",
    "eslint": "^9.37.0",
    "eslint-plugin-react": "^7.37.5",
    "globals": "^16.4.0",
    "jest": "^30.2.0",
    "jest-environment-jsdom": "^30.2.0",
    "jiti": "^2.6.1",
    "nodemon": "^3.1.14",
    "prettier": "^3.5.3",
    "rollup-plugin-visualizer": "^6.0.5",
    "ts-jest": "^29.4.5",
    "ts-node": "^10.9.2",
    "tsx": "^4.20.6",
    "typescript": "^5.7.2",
    "typescript-eslint": "^8.45.0",
    "vite": "^6.0.0"
  },
  "dependencies": {
    "@sun/ssr": "^0.2.1",
    "@sun/components": "^0.7.1",
    "@sun/utils": "^0.1.1",
    "@posthog/react": "^1.9.0",
    "@heroicons/react": "^2.2.0",
    "@testing-library/user-event": "^14.6.1",
    "@vitejs/plugin-react-swc": "^3.7.0",
    "brotli": "^1.3.3",
    "cross-env": "^7.0.3",
    "dotenv": "^16.5.0",
    "fastify": "^5.9.0",
    "@fastify/compress": "^8.3.1",
    "@fastify/http-proxy": "^11.4.4",
    "@fastify/middie": "^9.3.2",
    "@fastify/static": "^9.1.3",
    "i18next": "^25.0.0",
    "lucide-react": "^0.554.0",
    "posthog-node": "^5.21.2",
    "react": "19.0.0",
    "react-dom": "19.0.0",
    "react-i18next": "^15.4.1",
    "react-router-dom": "^6.22.0"
  }
}
